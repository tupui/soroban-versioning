---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/layout/Container.astro";
import ProjectInfo from "../../components/page/project/ProjectInfo.astro";
import ProjectInfoTitle from "../../components/page/project/ProjectInfoTitle.astro";
---

<script is:inline>
  var global = global || window;
</script>

<Layout title="Tansu" page="project">
  <Container>
    <ProjectInfoTitle />
    <ProjectInfo />
  </Container>
</Layout>

<script>
  import { fetchTomlFromIpfs } from "../../utils/ipfsFunctions";
  import {
    getProjectFromName,
    getProjectHash,
  } from "../../service/ReadContractService";
  import {
    refreshLocalStorage,
    setConfigData,
    setProject,
    setProjectId,
    setProjectLatestSha,
    setProjectRepoInfo,
  } from "../../service/StateService";
  import { getAuthorRepo } from "../../utils/editLinkFunctions";
  import { projectHasSubProjects, projectInfoLoaded } from "../../utils/store";
  import { extractConfigData, toast } from "../../utils/utils";

  document.addEventListener("astro:page-load", async () => {
    const urlParams = new URLSearchParams(window.location.search);
    const projectName = urlParams.get("name") || "";
    if (!projectName) {
      window.location.href = "/";
      return;
    }
    projectHasSubProjects.set(false);
    {
      setProjectId(projectName);
      try {
        const project = await getProjectFromName(projectName);
        if (project && project.name && project.config && project.maintainers) {
          setProject(project);

          const tomlData = await fetchTomlFromCid(project.config.ipfs);
          let configData: any = {};
          if (tomlData) {
            configData = extractConfigData(tomlData, project);
            setConfigData(configData);
          } else {
            setConfigData({});
          }

          // Only set GitHub repo info for SOFTWARE projects
          const isSoftwareProject = configData.projectType === "SOFTWARE";
          if (isSoftwareProject) {
            const { username, repoName } = getAuthorRepo(project.config.url);
            if (username && repoName) {
              setProjectRepoInfo(username, repoName);
            }

            try {
              const latestSha = await getProjectHash();
              if (
                latestSha &&
                typeof latestSha === "string" &&
                latestSha.match(/^[a-f0-9]{40}$/)
              ) {
                setProjectLatestSha(latestSha);
              } else {
                setProjectLatestSha("");
              }
            } catch (error: any) {
              toast.error("Something Went Wrong!", error.message);
            }
          }

          projectInfoLoaded.set(true);

          (async () => {
            const [tomlResult, hashResult] = await Promise.allSettled([
              fetchTomlFromIpfs(project.config.ipfs),
              getProjectHash(),
            ]);
            if (tomlResult.status === "fulfilled" && tomlResult.value) {
              setConfigData(extractConfigData(tomlResult.value, project));
            }
            const sha =
              hashResult.status === "fulfilled" ? hashResult.value : null;
            setProjectLatestSha(
              sha && typeof sha === "string" && /^[a-f0-9]{40}$/.test(sha)
                ? sha
                : "",
            );
            if (hashResult.status === "rejected") {
              toast.error("Something Went Wrong!", hashResult.reason?.message);
            }
          })();
        } else {
          refreshLocalStorage();
          window.location.href = "/";
        }
      } catch (error: any) {
        if (import.meta.env.DEV) {
          console.error("Error fetching project info:", error);
        }
        toast.error("Something Went Wrong!", error.message);
        refreshLocalStorage();
        window.location.href = "/";
      }
    }
  });
</script>
