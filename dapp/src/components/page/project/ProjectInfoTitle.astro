---
import UpdateConfigModal from "./UpdateConfigModal";
import UpdateHashModal from "./UpdateHashModal";
import AddBadgeModal from "./AddBadgeModal";
import ManageSubProjectsModal from "./ManageSubProjectsModal";
---

<!-- Navigation: vertical stack on small screens (2x2 grid), single row from md up -->
<div
  class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 md:gap-0 mb-4 md:mb-0"
>
  <a
    href="/"
    class="flex gap-[14px] items-center min-w-0 shrink-0 whitespace-nowrap transition-colors hover:opacity-80"
  >
    <img src="/icons/back.svg" alt="Back" />
    <p class="leading-5 text-base md:text-xl text-primary">Back to Home</p>
  </a>
  <div class="grid grid-cols-2 gap-2 w-full md:w-auto md:grid-cols-4 md:gap-3">
    <UpdateConfigModal client:only />
    <AddBadgeModal client:only />
    <UpdateHashModal client:only />
    <ManageSubProjectsModal client:only />
  </div>
</div>
